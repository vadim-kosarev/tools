# brightsky не резолвится с этого dev-хоста напрямую (не в докере) - используем IP
IMMICH_URL=http://192.168.1.43:2283
# API-ключ должен принадлежать именно тому пользователю, чьи теги/persons нужно менять
# (создаётся в Immich UI: User Settings -> API Keys, залогинившись под этим пользователем)
IMMICH_API_KEY=
LOG_LEVEL=INFO

# tag_frequent_faces.py
tag_frequent_faces.config.library-id=
tag_frequent_faces.config.source-folders=frigate,dashcam
tag_frequent_faces.config.gap-hours=1
tag_frequent_faces.config.tag-name=Frequent
tag_frequent_faces.config.mark-favorite=true

# run_sql.py (и любой другой скрипт, ходящий в Immich Postgres напрямую)
IMMICH_DB_HOST=192.168.1.43
IMMICH_DB_PORT=5432
IMMICH_DB_NAME=immich
IMMICH_DB_USER=postgres
IMMICH_DB_PASSWORD=
