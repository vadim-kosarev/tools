"""
LangGraph-агент для single-pass анализа с полным логированием.

НОВАЯ АРХИТЕКТУРА (один проход):
    START -> plan_node -> action_node -> observation_node -> final_node -> END

Следует system_prompt.md:
  - plan: анализ вопроса, построение стратегии
  - action: вызов tools
  - observation: анализ результатов
  - final: формирование ответа

КЛЮЧЕВЫЕ ОТЛИЧИЯ ОТ ПРЕДЫДУЩЕЙ ВЕРСИИ:
  - Один проход без итераций
  - Использует LLMConversation для структурированного общения
  - Полное логирование всех messages (system, user, assistant, tool)
  - Строгое следование JSON schema из system_prompt.md

Состояние агента (AgentState):
    - user_query: вопрос пользователя
    - step: текущий шаг (1-4)
    - messages: история LLM сообщений
    - plan: план поиска
    - tool_calls: вызовы инструментов
    - tool_results: результаты инструментов
    - observation: анализ результатов
    - final_answer: итоговый ответ

Узлы (следуют system_prompt.md):
    1. plan_node        - status: plan, формирует стратегию поиска
    2. action_node      - status: action, вызывает tools
    3. observation_node - status: observation, анализирует результаты
    4. final_node       - status: final, формирует ответ

Логирование через LangChainFileLogger:
    - Все system prompts
    - Все user messages
    - Все assistant responses (JSON)
    - Все tool calls и results
    - Полная история messages

Использование:
    python rag_lg_agent.py "найди все СУБД"
    python rag_lg_agent.py --verbose
"""

from __future__ import annotations

import argparse
import json
import logging
import sys
from pathlib import Path
from typing import Any, Literal, TypedDict

if hasattr(sys.stdout, "reconfigure"):
    sys.stdout.reconfigure(encoding="utf-8")
if hasattr(sys.stderr, "reconfigure"):
    sys.stderr.reconfigure(encoding="utf-8")

from dotenv import load_dotenv
from pydantic import BaseModel, Field

load_dotenv()

from langgraph.graph import StateGraph, END
from langchain_ollama import ChatOllama
from langchain_core.messages import BaseMessage, HumanMessage, AIMessage

import rag_chat
from rag_chat import build_vectorstore, settings
from kb_tools import create_kb_tools, AGENT_SELECTABLE_TOOLS, get_tool_registry
from llm_call_logger import LangChainFileLogger, LlmCallLogger
from llm_messages import LLMConversation, execute_tool_calls
from pydantic_utils import pydantic_to_markdown, get_result_count, format_result_summary, format_sections_list
from system_prompts import get_prompt_by_name, load_system_prompt
from logging_config import setup_logging

logger = setup_logging("rag_lg_agent")

# ---------------------------------------------------------------------------
# Состояние агента (State)
# ---------------------------------------------------------------------------

class AgentState(TypedDict):
    """Состояние single-pass агента."""
    user_query: str
    step: int
    messages: list[dict[str, Any]]  # История LLM сообщений
    plan: list[str]  # План поиска
    tool_calls: list[dict[str, Any]]  # [{tool, input}]
    tool_results: list[dict[str, Any]]  # [{tool, result}]
    observation: str  # Анализ результатов
    final_answer: str  # Итоговый ответ (JSON)


# ---------------------------------------------------------------------------
# Pydantic модели для JSON ответов (следуют system_prompt.md)
# ---------------------------------------------------------------------------

class AgentPlan(BaseModel):
    """Ответ на этапе plan (следует system_prompt.md)."""
    status: Literal["plan"] = Field(default="plan")
    step: int = Field(description="Номер шага")
    thought: str = Field(description="Краткое рассуждение (1-2 предложения)")
    plan: list[str] = Field(
        description="Список шагов плана поиска (3-5 пунктов)"
    )


class ToolAction(BaseModel):
    """Один вызов инструмента."""
    tool: str = Field(description="Имя инструмента")
    input: dict[str, Any] = Field(description="Параметры инструмента")


class AgentAction(BaseModel):
    """Ответ на этапе action (следует system_prompt.md)."""
    status: Literal["action"] = Field(default="action")
    step: int = Field(description="Номер шага")
    thought: str = Field(description="Краткое рассуждение")
    action: list[ToolAction] = Field(
        description="Список вызовов инструментов (2-4 штуки для параллельного выполнения)"
    )


class AgentObservation(BaseModel):
    """Ответ на этапе observation (следует system_prompt.md)."""
    status: Literal["observation"] = Field(default="observation")
    step: int = Field(description="Номер шага")
    thought: str = Field(description="Краткое рассуждение")
    observation: str = Field(
        description="Анализ результатов: что нашли, что не нашли, что важно"
    )


class FinalAnswerData(BaseModel):
    """Структурированные данные в ответе."""
    entity: str
    attribute: str
    value: str


class FinalAnswer(BaseModel):
    """Финальный ответ (inner structure)."""
    summary: str = Field(description="Краткий ответ")
    details: str = Field(description="Подробное объяснение")
    data: list[FinalAnswerData] = Field(
        default_factory=list,
        description="Структурированные данные"
    )
    sources: list[str] = Field(default_factory=list, description="Источники")
    confidence: float = Field(ge=0.0, le=1.0, description="Уверенность (0-1)")


class AgentFinal(BaseModel):
    """Ответ на этапе final (следует system_prompt.md)."""
    status: Literal["final"] = Field(default="final")
    step: int = Field(description="Номер шага")
    thought: str = Field(description="Краткое рассуждение")
    final_answer: FinalAnswer = Field(description="Итоговый ответ")


class AnalysisResult(BaseModel):
    """Результат анализа найденных данных."""
    found_entities: list[dict[str, Any]] = Field(
        description=(
            "Список найденных сущностей (IP, СУБД, системы и т.д.) ТОЛЬКО из результата инструмента.\n"
            "Формат: [{\"type\": \"ip\", \"value\": \"10.0.0.1\", \"source\": \"file.md\", \"context\": \"цитата из документа\"}]\n"
            "ВАЖНО: Если в результате инструмента ничего не найдено - список должен быть ПУСТЫМ [].\n"
            "НЕ придумывай данные! Только то, что есть в результате."
        )
    )
    evidence: list[str] = Field(
        description=(
            "Доказательства: ТОЧНЫЕ цитаты из найденных документов, подтверждающие находки.\n"
            "Каждая цитата должна быть ДОСЛОВНОЙ из результата инструмента.\n"
            "Если инструмент вернул 'Ничего не найдено' - список пустой []."
        )
    )
    gaps: list[str] = Field(
        description=(
            "Выявленные пробелы:\n"
            "  - Что НЕ найдено из исходного вопроса\n"
            "  - Какие термины не дали результатов\n"
            "  - Какие гипотезы не подтверждены\n"
            "Если инструмент ничего не нашел - укажи что именно не найдено."
        )
    )
    summary: str = Field(
        description=(
            "Краткая сводка найденного на данном шаге (1-2 предложения).\n"
            "Основывайся ТОЛЬКО на результате инструмента.\n"
            "Если ничего не найдено - так и напиши: 'Ничего не найдено по запросу X'."
        )
    )


# ---------------------------------------------------------------------------
# LLM call logger (singleton)
# ---------------------------------------------------------------------------

_llm_logger: LlmCallLogger | None = None


def _get_llm_logger() -> LlmCallLogger:
    """Returns the process-level LlmCallLogger instance (lazy init)."""
    global _llm_logger
    if _llm_logger is None:
        _llm_logger = LlmCallLogger(
            enabled=settings.llm_log_enabled,
            log_dir=Path(__file__).parent / "logs",
            stream_to_console=True,
        )
    return _llm_logger


# ---------------------------------------------------------------------------
# Загрузка system prompt из файла
# ---------------------------------------------------------------------------

def _load_system_prompt() -> str:
    """Загружает system_prompt.md как базовый промпт для агента."""
    prompt_path = Path(__file__).parent / "system_prompt.md"
    if prompt_path.exists():
        return prompt_path.read_text(encoding="utf-8")
    else:
        logger.warning(f"system_prompt.md не найден в {prompt_path}")
        return "Ты - аналитический AI-агент"


_SYSTEM_PROMPT = _load_system_prompt():
    """Системный промпт для planner (генерация гипотез).
    
    Использует принципы из analytical_agent промпта:
      - Работа ТОЛЬКО с фактами из tools
      - Итеративный подход (plan → action → observe)
      - Честное признание отсутствия данных
    """
    return """Ты - эксперт по анализу технических вопросов и планированию стратегии поиска.

ОСНОВНОЙ ПРИНЦИП (из analytical_agent):
  - Ты НЕ отвечаешь сразу
  - Ты работаешь итеративно: plan → action → observe → conclude
  - Работа ТОЛЬКО с информацией из инструментов (tools)
  - ЗАПРЕЩЕНО придумывать, домысливать или использовать общие знания

ТВОЯ ЗАДАЧА:
Проанализируй вопрос пользователя и сформируй:
  1. Список гипотез - где и как искать ответ в ТЕХНИЧЕСКОЙ ДОКУМЕНТАЦИИ
  2. Ключевые термины для точного поиска
  3. Семантические запросы для концептуального поиска
  4. Regex-паттерны (если нужны IP, порты, подсети)

СТРАТЕГИЯ ПЛАНИРОВАНИЯ:
  - Гипотезы должны быть реалистичны для технической документации
  - Формулируй как 'может быть в разделах о X' или 'в таблицах Y'
  - Агент сам найдёт релевантные разделы по результатам поиска
  - Ключевые термины = конкретные названия, коды, аббревиатуры из вопроса
  - Семантические запросы = естественные описания темы для векторного поиска

ЧТО ИЩЕМ:
  - Описания систем, архитектуры, компонентов
  - Таблицы конфигураций, характеристик, инвентаризации
  - Технические параметры, IP-адреса, порты, подсети
  - Спецификации, инструкции, регламенты

ВАЖНО:
  - НЕ предполагай, что информация обязательно есть
  - Будь готов к тому, что данных может не быть
  - Фокусируйся на конкретных поисковых запросах, а не на абстрактных разделах

Отвечай ТОЛЬКО структурированным объектом SearchHypotheses.
Никаких пояснений вне структуры."""


def _build_tool_selector_system(available_tools: list[str]) -> str:
    """Системный промпт для tool_selector.
    
    Аналог статуса "action" из analytical_agent промпта.
    """
    tools_list = ", ".join(available_tools)
    
    # Получаем описания инструментов из реестра
    tool_registry = get_tool_registry()
    tools_descriptions = "\n".join(
        f"  - {name}: {tool_registry.get(name, '?')}"
        for name in available_tools
    )
    
    return (
        "Ты - эксперт по выбору инструментов поиска.\n\n"
        "ОСНОВНОЙ ПРИНЦИП (из analytical_agent):\n"
        "  - Статус: action - выбор и вызов инструмента\n"
        "  - Работай ТОЛЬКО с доступными tools\n"
        "  - Каждое действие должно быть обосновано\n"
        "  - Избегай повторных запросов\n\n"
        f"Доступные инструменты: {tools_list}\n\n"
        "ОПИСАНИЕ ИНСТРУМЕНТОВ:\n"
        f"{tools_descriptions}\n\n"
        "ПАРАМЕТРЫ ИНСТРУМЕНТОВ (ОБЯЗАТЕЛЬНО СОБЛЮДАЙ ТОЧНЫЕ НАЗВАНИЯ):\n"
        "  1. semantic_search:\n"
        "       {\"query\": \"текст запроса\", \"top_k\": 10}\n"
        "  2. exact_search:\n"
        "       {\"substring\": \"точная подстрока\", \"limit\": 30}\n"
        "  3. multi_term_exact_search:\n"
        "       {\"terms\": [\"термин1\", \"термин2\"], \"limit\": 30}\n"
        "  4. regex_search:\n"
        "       {\"pattern\": r\"regex-паттерн\", \"max_results\": 50}\n"
        "  5. read_table:\n"
        "       {\"section\": \"название раздела\", \"limit\": 50}\n"
        "  6. get_section_content:\n"
        "       {\"source_file\": \"имя_файла.md\", \"section\": \"название раздела\"}\n"
        "  7. list_sections:\n"
        "       {\"source_file\": \"имя_файла.md\"}  или  {}\n"
        "  8. get_neighbor_chunks:\n"
        "       {\"source\": \"file.md\", \"line_start\": 123, \"before\": 5, \"after\": 5}\n\n"
        "На основе текущего состояния (гипотезы, история поиска, пробелы) выбери:\n"
        "  - Следующий инструмент для вызова\n"
        "  - Аргументы для инструмента (ТОЧНО по схеме выше)\n"
        "  - Обоснование выбора\n\n"
        "Избегай повторных запросов (проверяй search_history).\n"
        "Отвечай ТОЛЬКО структурированным объектом ToolSelection.\n"
        "Никаких пояснений вне структуры."
    )


def _build_analyzer_system() -> str:
    """Системный промпт для analyzer.
    
    Аналог статуса "observation" из analytical_agent промпта.
    """
    return (
        "Ты - аналитик данных по технической документации.\n\n"
        "ОСНОВНОЙ ПРИНЦИП (из analytical_agent):\n"
        "  - Статус: observation - обработка результатов инструмента\n"
        "  - Извлекай ТОЛЬКО информацию из результата инструмента\n"
        "  - ЗАПРЕЩЕНО придумывать, домысливать или добавлять от себя\n"
        "  - Честно признавай отсутствие данных\n\n"
        "ТВОЯ ЗАДАЧА:\n"
        "Изучи результаты последнего поиска и извлеки:\n"
        "  1. Найденные сущности (IP, СУБД, системы) с контекстом\n"
        "  2. Доказательства (цитаты из документов)\n"
        "  3. Выявленные пробелы (что не найдено из вопроса)\n"
        "  4. Краткую сводку\n\n"
        "КРИТИЧЕСКИ ВАЖНО:\n"
        "  - Извлекай ТОЛЬКО информацию из результата инструмента\n"
        "  - НЕ придумывай, НЕ домысливай, НЕ добавляй от себя\n"
        "  - Если в результатах ничего нет - gaps должны это отражать\n"
        "  - Доказательства = ТОЧНЫЕ цитаты из результата инструмента\n"
        "  - Если результат 'Ничего не найдено' - found_entities должен быть пустым\n\n"
        "Отвечай ТОЛЬКО структурированным объектом AnalysisResult.\n"
        "Никаких пояснений вне структуры."
    )


def _build_refiner_system() -> str:
    """Системный промпт для refiner.
    
    Решает продолжать ли итерацию (continue_search) или завершить (final).
    """
    return (
        "Ты - стратег поиска информации.\n\n"
        "ОСНОВНОЙ ПРИНЦИП (из analytical_agent):\n"
        "  - Решаешь: продолжить поиск или перейти к final\n"
        "  - Оценивай ТОЛЬКО реальные найденные данные\n"
        "  - НЕ предполагай, что данные 'где-то есть'\n"
        "  - Честно признавай недостаточность данных\n\n"
        "ОЦЕНИ ТЕКУЩЕЕ СОСТОЯНИЕ:\n"
        "  - Найденные данные (found_items) - что РЕАЛЬНО найдено\n"
        "  - Доказательства (evidence) - цитаты из документов\n"
        "  - Пробелы (gaps) - что НЕ найдено\n"
        "  - Количество шагов (step) - сколько попыток уже было\n\n"
        "РЕШИ:\n"
        "  - Достаточно ли РЕАЛЬНО НАЙДЕННЫХ данных для полного ответа?\n"
        "  - Нужно ли продолжить поиск?\n"
        "  - Какая следующая стратегия?\n\n"
        "ВАЖНО:\n"
        "  - Оценивай ТОЛЬКО то, что реально найдено в found_items\n"
        "  - НЕ предполагай, что данные 'где-то есть'\n"
        "  - Если found_items пуст или недостаточен - это реальность\n"
        "  - Учитывай количество шагов - не зацикливайся на бесполезных попытках\n"
        "  - Если после 3-4 попыток ничего не найдено - лучше завершить\n\n"
        "Отвечай ТОЛЬКО структурированным объектом RefinementDecision.\n"
        "Никаких пояснений вне структуры."
    )


def _build_finalizer_system() -> str:
    """Системный промпт для finalizer.
    
    Аналог статуса "final" из analytical_agent промпта.
    """
    return """Ты - эксперт-аналитик по технической документации.

ОСНОВНОЙ ПРИНЦИП (из analytical_agent):
  - Статус: final - формирование итогового ответа
  - Работа ТОЛЬКО с найденными данными (found_items, evidence)
  - ЗАПРЕЩЕНО придумывать, домысливать или использовать общие знания
  - Честное признание недостаточности данных

ТВОЯ ЗАДАЧА:
Сформируй финальный ответ на вопрос пользователя на основе:
  - Найденных данных (found_items)
  - Доказательств (evidence)
  - Всей истории поиска

СТРОГИЕ ПРАВИЛА ОТВЕТА:
  [!] ЗАПРЕЩЕНО придумывать, домысливать или добавлять информацию от себя
  [!] ЗАПРЕЩЕНО использовать общие знания или предположения
  [+] Используй ИСКЛЮЧИТЕЛЬНО данные из found_items и evidence
  [+] Каждое утверждение должно иметь источник из найденных данных
  [+] Приводи ТОЧНЫЕ цитаты с указанием источника [файл] - раздел
  [+] Структурируй ответ (списки, таблицы, подзаголовки)
  [+] Если данных недостаточно - ЧЕСТНО укажи что именно отсутствует
  [+] Если по вопросу ничего не найдено - так и скажи, не придумывай
  [+] Отвечай на русском языке

Если found_items пуст или содержит мало данных:
  - НЕ пытайся 'додумать' ответ
  - Честно сообщи: 'В документации не найдено информации по запросу'
  - Перечисли, что именно искалось (из истории поиска)
  - Укажи, какие gaps остались

ФОРМАТ ОТВЕТА (опционально):
  - summary: краткий ответ
  - details: подробное объяснение
  - data: структурированные данные [{entity, attribute, value}]
  - sources: список источников
  - confidence: уверенность (0-1)"""


# ---------------------------------------------------------------------------
# Узлы графа (Nodes)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# [ОТКЛЮЧЕНО] Prefetch sections
# Функция больше не вызывается в pipeline, начинаем сразу с planner
# ---------------------------------------------------------------------------

def prefetch_sections(state: AgentState) -> AgentState:
    """
    [ОТКЛЮЧЕНО] Предварительная загрузка списка всех доступных разделов документации.
    Вызывает list_all_sections и сохраняет результат в state для использования planner'ом.
    """
    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "PREFETCH_SECTIONS START",
        "Загрузка списка доступных разделов документации"
    )

    try:
        # Получаем vectorstore и создаём tools
        vectorstore = build_vectorstore(force_reindex=False)
        knowledge_dir = Path(settings.knowledge_dir)
        tools_list = create_kb_tools(
            vectorstore=vectorstore,
            knowledge_dir=knowledge_dir,
            semantic_top_k=settings.retriever_top_k,
            llm_logger=llm_logger,
        )

        # Находим list_all_sections
        list_all_sections_tool = next((t for t in tools_list if t.name == "list_all_sections"), None)

        if list_all_sections_tool:
            # Вызываем инструмент
            result = list_all_sections_tool.invoke({})
            # Форматируем полный список разделов для LLM промпта
            result_str = format_sections_list(result)
            state["available_sections"] = result_str

            # Получаем количество разделов
            sections_count = get_result_count(result)
            if sections_count is not None:
                logger.info(f"prefetch_sections завершён: загружено {sections_count} разделов")
                llm_logger.log_stage(
                    "PREFETCH_SECTIONS COMPLETE",
                    f"Успешно загружен список разделов\nКоличество разделов: {sections_count}"
                )
            else:
                logger.info(f"prefetch_sections завершён: загружено данных ({len(result_str)} символов)")
                llm_logger.log_stage(
                    "PREFETCH_SECTIONS COMPLETE",
                    f"Успешно загружен список разделов\nРазмер: {len(result_str)} символов"
                )
        else:
            logger.warning("Инструмент list_all_sections не найден")
            state["available_sections"] = "Список разделов не доступен"
            llm_logger.log_stage(
                "PREFETCH_SECTIONS WARNING",
                "Инструмент list_all_sections не найден"
            )

    except Exception as exc:
        logger.error(f"Ошибка prefetch_sections: {exc}", exc_info=True)
        state["available_sections"] = "Ошибка загрузки списка разделов"
        llm_logger.log_stage(
            "PREFETCH_SECTIONS ERROR",
            f"Ошибка: {exc}"
        )

    return state


def planner(state: AgentState) -> AgentState:
    """
    Анализирует запрос пользователя и генерирует гипотезы поиска.
    """
    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "PLANNER START",
        f"Шаг: {state['step']}\nВопрос: {state['user_query']}"
    )

    try:
        llm = rag_chat.build_llm()
        structured_llm = llm.with_structured_output(SearchHypotheses)

        invoke_config = {}
        if llm_logger._enabled:
            invoke_config = {
                "callbacks": [LangChainFileLogger(llm_logger, step_prefix="PLANNER")]
            }

        result: SearchHypotheses = structured_llm.invoke(
            [
                {"role": "system", "content": _build_planner_system()},
                {"role": "user", "content": f"Вопрос: {state['user_query']}"}
            ],
            config=invoke_config,
        )

        state["hypotheses"] = result.hypotheses
        state["key_terms"] = result.key_terms
        state["semantic_queries"] = result.semantic_queries

        logger.info(
            f"Planner завершил анализ\n"
            f"  Гипотез: {len(result.hypotheses)}\n"
            f"  Ключевые термины: {result.key_terms}\n"
            f"  Семантические запросы: {result.semantic_queries}\n"
            f"  IP-паттерны: {result.ip_patterns}"
        )

        llm_logger.log_stage(
            "PLANNER COMPLETE",
            f"Гипотез: {len(result.hypotheses)}\n"
            + "\n".join(f"  - {h}" for h in result.hypotheses[:5])
            + f"\nКлючевые термины: {', '.join(result.key_terms)}\n"
            + f"Семантические запросы: {', '.join(result.semantic_queries)}"
        )

    except Exception as exc:
        logger.error(f"Ошибка planner: {exc}", exc_info=True)
        state["hypotheses"] = ["Поиск по ключевым словам из вопроса"]
        state["key_terms"] = []
        state["semantic_queries"] = []

    return state


def section_finder(state: AgentState) -> AgentState:
    """
    Находит релевантные разделы через:
    1. exact_search по ключевым терминам (find_sections_by_term)
    2. semantic search по семантическим запросам (find_relevant_sections)

    Сохраняет все найденные разделы в found_sections с метаданными о релевантности.
    """
    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "SECTION_FINDER START",
        f"Ключевые термины: {', '.join(state.get('key_terms', []))}\n"
        f"Семантические запросы: {', '.join(state.get('semantic_queries', []))}"
    )

    key_terms = state.get("key_terms", [])
    semantic_queries = state.get("semantic_queries", [])

    if not key_terms and not semantic_queries:
        logger.info("Section finder: нет терминов и запросов для поиска разделов")
        llm_logger.log_stage(
            "SECTION_FINDER COMPLETE",
            "Нет терминов для поиска"
        )
        state["sections_searched"] = True
        return state
    
    try:
        #Получаем vectorstore и tools
        vectorstore = build_vectorstore(force_reindex=False)
        knowledge_dir = Path(settings.knowledge_dir)
        tools_list = create_kb_tools(
            vectorstore=vectorstore,
            knowledge_dir=knowledge_dir,
            semantic_top_k=settings.retriever_top_k,
            llm_logger=llm_logger,
        )
        
        # Находим необходимые инструменты
        find_sections_tool = next((t for t in tools_list if t.name == "find_sections_by_term"), None)
        find_relevant_tool = next((t for t in tools_list if t.name == "find_relevant_sections"), None)

        # Собираем разделы в словарь {(source, section): {relevance, mentions}}
        sections_dict = {}

        # 1. Поиск по ключевым терминам (exact search)
        if find_sections_tool and key_terms:
            logger.info(f"Поиск разделов по {len(key_terms)} ключевым терминам...")

            for term in key_terms[:5]:  # Ограничиваем до 5
                try:
                    result = find_sections_tool.invoke({"substring": term, "limit": 50})

                    # Парсим результат (формат: "[F] file.md:\n   • Section Name (N упоминаний)\n")
                    lines = str(result).split('\n')
                    current_file = ""

                    for line in lines:
                        line = line.strip()
                        if line.startswith('[F] ') and line.endswith(':'):
                            current_file = line[4:-1].strip()
                        elif line.startswith('•') and current_file:
                            # Извлекаем название раздела и количество упоминаний
                            section_line = line[1:].strip()
                            mentions = 0

                            if '(' in section_line:
                                section_name = section_line[:section_line.index('(')].strip()
                                # Попытка извлечь число упоминаний
                                try:
                                    mentions_str = section_line[section_line.index('(')+1:section_line.index(')')]
                                    mentions = int(mentions_str.split()[0])
                                except:
                                    pass
                            else:
                                section_name = section_line

                            key = (current_file, section_name)
                            if key not in sections_dict:
                                sections_dict[key] = {"relevance": "exact", "mentions": 0, "terms": []}
                            sections_dict[key]["mentions"] += mentions
                            sections_dict[key]["terms"].append(term)

                except Exception as exc:
                    logger.warning(f"Ошибка поиска разделов по термину '{term}': {exc}")
                    continue

        # 2. Поиск по семантическим запросам
        if find_relevant_tool and semantic_queries:
            logger.info(f"Семантический поиск разделов по {len(semantic_queries)} запросам...")

            for query in semantic_queries[:3]:  # Ограничиваем до 3
                try:
                    result = find_relevant_tool.invoke({
                        "query": query,
                        "exact_terms": key_terms[:3] if key_terms else [],
                        "limit": 30
                    })

                    # Парсим результат
                    lines = str(result).split('\n')
                    current_file = ""

                    for line in lines:
                        line = line.strip()
                        if line.startswith('[F] ') and line.endswith(':'):
                            current_file = line[4:-1].strip()
                        elif line.startswith('🎯') or line.startswith('•'):
                            # Извлекаем название раздела
                            if line.startswith('🎯'):
                                section_line = line[2:].strip()
                            else:
                                section_line = line[1:].strip()

                            # Убираем метки и количество чанков
                            section_name = section_line.split('[')[0].strip()
                            if '(' in section_name:
                                section_name = section_name[:section_name.index('(')].strip()

                            if current_file:
                                key = (current_file, section_name)
                                if key not in sections_dict:
                                    sections_dict[key] = {"relevance": "semantic", "mentions": 0, "terms": []}
                                # Повышаем релевантность если раздел найден и точным и семантическим поиском
                                if sections_dict[key]["relevance"] == "exact":
                                    sections_dict[key]["relevance"] = "both"

                except Exception as exc:
                    logger.warning(f"Ошибка семантического поиска разделов по запросу '{query}': {exc}")
                    continue

        # Конвертируем в список для found_sections
        found_sections = [
            {
                "source": source,
                "section": section,
                "relevance": data["relevance"],
                "mentions": data["mentions"],
                "terms": data["terms"]
            }
            for (source, section), data in sections_dict.items()
        ]

        # Сортируем: сначала "both", потом "exact" с большим числом упоминаний, потом "semantic"
        def section_sort_key(s):
            relevance_order = {"both": 0, "exact": 1, "semantic": 2}
            return (relevance_order.get(s["relevance"], 3), -s["mentions"])

        found_sections.sort(key=section_sort_key)

        state["found_sections"] = found_sections
        state["sections_searched"] = True

        logger.info(
            f"Section finder завершил работу\n"
            f"  Найдено разделов: {len(found_sections)}\n"
            f"  - both (exact + semantic): {sum(1 for s in found_sections if s['relevance'] == 'both')}\n"
            f"  - exact only: {sum(1 for s in found_sections if s['relevance'] == 'exact')}\n"
            f"  - semantic only: {sum(1 for s in found_sections if s['relevance'] == 'semantic')}"
        )
        
        llm_logger.log_stage(
            "SECTION_FINDER COMPLETE",
            f"Найдено разделов: {len(found_sections)}\n"
            + "\n".join(f"  [{s['relevance']}] {s['source']} - {s['section']} ({s['mentions']} упоминаний)"
                       for s in found_sections[:10])
        )
        
    except Exception as exc:
        logger.error(f"Ошибка section_finder: {exc}", exc_info=True)
        llm_logger.log_stage(
            "SECTION_FINDER ERROR",
            f"Ошибка: {exc}"
        )
        state["sections_searched"] = True

    return state


def tool_selector(state: AgentState) -> AgentState:
    """
    Выбирает следующий инструмент и формирует поисковый запрос.
    """
    # Инкремент счетчика шагов
    state["step"] = state["step"] + 1

    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "TOOL_SELECTOR START",
        f"Шаг: {state['step']}\n"
        f"История поиска: {len(state['search_history'])} запросов\n"
        f"Найдено элементов: {len(state['found_items'])}\n"
        f"Gaps: {len(state['gaps'])}"
    )

    try:
        llm = rag_chat.build_llm()
        structured_llm = llm.with_structured_output(ToolSelection)

        # Используем централизованный реестр инструментов
        available_tools = AGENT_SELECTABLE_TOOLS

        # Формируем контекст с реальными данными (не только счётчики!)
        context_parts = [
            f"Вопрос: {state['user_query']}\n",
            "Гипотезы:",
            "\n".join(f"  - {h}" for h in state['hypotheses']),
            "\nИстория поиска:",
            "\n".join(f"  - {q}" for q in state['search_history'][-5:])
        ]
        
        # Показываем последние найденные элементы (не только счётчик!)
        if state['found_items']:
            context_parts.append(f"\nНайденные элементы ({len(state['found_items'])} всего, последние 5):")
            for item in state['found_items'][-5:]:
                context_parts.append(f"  • {json.dumps(item, ensure_ascii=False)}")
        else:
            context_parts.append("\nНайденные элементы: пока ничего не найдено")
        
        # Показываем последние доказательства
        if state['evidence']:
            context_parts.append(f"\nДоказательства ({len(state['evidence'])} всего, последние 3):")
            for e in state['evidence'][-3:]:
                context_parts.append(f"  - {e}")
        
        # Показываем текущие пробелы
        if state['gaps']:
            context_parts.append("\nПробелы:")
            context_parts.append("\n".join(f"  - {g}" for g in state['gaps'][-5:]))
        
        context = "\n".join(context_parts)

        invoke_config = {}
        if llm_logger._enabled:
            invoke_config = {
                "callbacks": [LangChainFileLogger(llm_logger, step_prefix="TOOL_SELECTOR")]
            }

        result: ToolSelection = structured_llm.invoke(
            [
                {"role": "system", "content": _build_tool_selector_system(available_tools)},
                {"role": "user", "content": context}
            ],
            config=invoke_config,
        )

        state["last_tool"] = result.tool_name
        state["last_query"] = json.dumps(result.tool_args, ensure_ascii=False)

        logger.info(
            f"Tool selector выбрал\n"
            f"  Инструмент: {result.tool_name}\n"
            f"  Аргументы: {state['last_query'][:100]}\n"
            f"  Обоснование: {result.reasoning}"
        )

        llm_logger.log_stage(
            "TOOL_SELECTOR COMPLETE",
            f"Выбран: {result.tool_name}\n"
            f"Аргументы: {state['last_query']}\n"
            f"Обоснование: {result.reasoning}"
        )

    except Exception as exc:
        logger.error(f"Ошибка tool_selector: {exc}", exc_info=True)
        # Fallback: semantic_search с исходным вопросом
        state["last_tool"] = "semantic_search"
        state["last_query"] = json.dumps({"query": state["user_query"], "top_k": 10})

    return state


def tool_executor(state: AgentState) -> AgentState:
    """
    Выполняет выбранный инструмент (без LLM).
    """
    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "TOOL_EXECUTOR START",
        f"Инструмент: {state['last_tool']}\nАргументы: {state['last_query']}"
    )

    try:
        tool_name = state["last_tool"]
        tool_args = json.loads(state["last_query"])

        # Автоисправление типичных ошибок в параметрах
        tool_args = _fix_tool_args(tool_name, tool_args)

        # Получаем vectorstore и tools
        vectorstore = build_vectorstore(force_reindex=False)
        knowledge_dir = Path(settings.knowledge_dir)
        tools_list = create_kb_tools(
            vectorstore=vectorstore,
            knowledge_dir=knowledge_dir,
            semantic_top_k=settings.retriever_top_k,
            llm_logger=llm_logger,
        )

        # Находим нужный инструмент
        tool = next((t for t in tools_list if t.name == tool_name), None)

        if tool is None:
            logger.warning(f"Инструмент {tool_name} не найден")
            state["last_result"] = f"Инструмент {tool_name} не найден"
            return state

        # Вызываем инструмент
        result = tool.invoke(tool_args)
        state["last_result"] = result

        # Добавляем в историю
        query_signature = f"{tool_name}({json.dumps(tool_args, ensure_ascii=False)[:50]})"
        state["search_history"].append(query_signature)

        # Формируем сводку о результате
        result_summary = format_result_summary(result)
        
        logger.info(
            f"Tool executor выполнил {tool_name}\n"
            f"  Результат: {result_summary}"
        )

        llm_logger.log_stage(
            "TOOL_EXECUTOR COMPLETE",
            f"Инструмент: {tool_name}\nРезультат: {result_summary}"
        )

    except Exception as exc:
        logger.error(f"Ошибка tool_executor: {exc}", exc_info=True)
        state["last_result"] = f"Ошибка выполнения: {exc}"

    return state


def _fix_tool_args(tool_name: str, tool_args: dict[str, Any]) -> dict[str, Any]:
    """
    Автоматически исправляет типичные ошибки в параметрах инструментов.

    Args:
        tool_name: Название инструмента
        tool_args: Исходные аргументы от LLM

    Returns:
        Исправленные аргументы
    """
    fixed_args = tool_args.copy()
    
    # exact_search: query -> substring
    if tool_name == "exact_search":
        if "query" in fixed_args and "substring" not in fixed_args:
            fixed_args["substring"] = fixed_args.pop("query")
            logger.debug(f"Исправлено: query -> substring для exact_search")
    
    # find_sections_by_term: term -> substring
    if tool_name == "find_sections_by_term":
        if "term" in fixed_args and "substring" not in fixed_args:
            fixed_args["substring"] = fixed_args.pop("term")
            logger.debug(f"Исправлено: term -> substring для find_sections_by_term")
        if "query" in fixed_args and "substring" not in fixed_args:
            fixed_args["substring"] = fixed_args.pop("query")
            logger.debug(f"Исправлено: query -> substring для find_sections_by_term")
    
    # semantic_search: text/search -> query
    if tool_name == "semantic_search":
        if "text" in fixed_args and "query" not in fixed_args:
            fixed_args["query"] = fixed_args.pop("text")
            logger.debug(f"Исправлено: text -> query для semantic_search")
        if "search" in fixed_args and "query" not in fixed_args:
            fixed_args["query"] = fixed_args.pop("search")
            logger.debug(f"Исправлено: search -> query для semantic_search")
    
    # regex_search: regex/query -> pattern
    if tool_name == "regex_search":
        if "regex" in fixed_args and "pattern" not in fixed_args:
            fixed_args["pattern"] = fixed_args.pop("regex")
            logger.debug(f"Исправлено: regex -> pattern для regex_search")
        if "query" in fixed_args and "pattern" not in fixed_args:
            fixed_args["pattern"] = fixed_args.pop("query")
            logger.debug(f"Исправлено: query -> pattern для regex_search")
    
    # read_table: query/name -> section
    if tool_name == "read_table":
        if "query" in fixed_args and "section" not in fixed_args:
            fixed_args["section"] = fixed_args.pop("query")
            logger.debug(f"Исправлено: query -> section для read_table")
        if "name" in fixed_args and "section" not in fixed_args:
            fixed_args["section"] = fixed_args.pop("name")
            logger.debug(f"Исправлено: name -> section для read_table")
    
    # get_section_content: file/filename -> source_file
    if tool_name == "get_section_content":
        if "file" in fixed_args and "source_file" not in fixed_args:
            fixed_args["source_file"] = fixed_args.pop("file")
            logger.debug(f"Исправлено: file -> source_file для get_section_content")
        if "filename" in fixed_args and "source_file" not in fixed_args:
            fixed_args["source_file"] = fixed_args.pop("filename")
            logger.debug(f"Исправлено: filename -> source_file для get_section_content")
    
    # list_sections: file/filename -> source_file
    if tool_name == "list_sections":
        if "file" in fixed_args and "source_file" not in fixed_args:
            fixed_args["source_file"] = fixed_args.pop("file")
            logger.debug(f"Исправлено: file -> source_file для list_sections")
        if "filename" in fixed_args and "source_file" not in fixed_args:
            fixed_args["source_file"] = fixed_args.pop("filename")
            logger.debug(f"Исправлено: filename -> source_file для list_sections")
    
    return fixed_args


def analyzer(state: AgentState) -> AgentState:
    """
    Извлекает полезные данные из результатов и формирует gaps.
    """
    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "ANALYZER START",
        f"Анализ результата инструмента: {state['last_tool']}"
    )

    try:
        llm = rag_chat.build_llm()
        structured_llm = llm.with_structured_output(AnalysisResult)

        # Формируем контекст с реальными данными для лучшего анализа
        context_parts = [
            f"Вопрос пользователя: {state['user_query']}\n",
            f"Использованный инструмент: {state['last_tool']}",
            f"Аргументы: {state['last_query']}\n",
            f"Результат инструмента:\n{str(state['last_result'])[:3000]}\n"
        ]

        # Показываем что уже найдено ранее (для контекста)
        if state['found_items']:
            context_parts.append(f"Уже найдено ранее ({len(state['found_items'])} элементов, последние 3):")
            for item in state['found_items'][-3:]:
                context_parts.append(f"  • {json.dumps(item, ensure_ascii=False)}")
        else:
            context_parts.append("Ранее ничего не найдено")

        # Показываем текущие пробелы
        if state['gaps']:
            context_parts.append("\nТекущие пробелы:")
            context_parts.append("\n".join(f"  - {g}" for g in state['gaps'][-5:]))

        context = "\n".join(context_parts)

        invoke_config = {}
        if llm_logger._enabled:
            invoke_config = {
                "callbacks": [LangChainFileLogger(llm_logger, step_prefix="ANALYZER")]
            }

        result: AnalysisResult = structured_llm.invoke(
            [
                {"role": "system", "content": _build_analyzer_system()},
                {"role": "user", "content": context}
            ],
            config=invoke_config,
        )

        # Обновляем состояние
        state["found_items"].extend(result.found_entities)
        state["evidence"].extend(result.evidence)
        state["gaps"] = result.gaps  # Заменяем gaps новыми

        logger.info(
            f"Analyzer завершил анализ\n"
            f"  Найдено сущностей: {len(result.found_entities)}\n"
            f"  Доказательств: {len(result.evidence)}\n"
            f"  Пробелов: {len(result.gaps)}\n"
            f"  Сводка: {result.summary}"
        )

        llm_logger.log_stage(
            "ANALYZER COMPLETE",
            f"Найдено сущностей: {len(result.found_entities)}\n"
            f"Доказательств: {len(result.evidence)}\n"
            f"Пробелов: {len(result.gaps)}\n"
            f"Сводка: {result.summary}"
        )

    except Exception as exc:
        logger.error(f"Ошибка analyzer: {exc}", exc_info=True)
        # Fallback: просто добавляем результат как есть
        state["gaps"] = ["Не удалось проанализировать результаты"]

    return state


def refiner(state: AgentState) -> AgentState:
    """
    Решает, продолжать поиск или завершить.
    Учитывает gaps и текущие результаты.
    """
    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "REFINER START",
        f"Шаг: {state['step']}\n"
        f"Найдено: {len(state['found_items'])} элементов\n"
        f"Пробелов: {len(state['gaps'])}"
    )

    # Проверка на максимальное количество шагов
    if state["step"] >= 6:
        state["done"] = True
        logger.info("Refiner: достигнут лимит шагов (6), завершение")
        llm_logger.log_stage("REFINER COMPLETE", "Достигнут лимит шагов -> завершение")
        return state

    try:
        llm = rag_chat.build_llm()
        structured_llm = llm.with_structured_output(RefinementDecision)

        # Формируем детальный контекст для принятия решения
        context_parts = [
            f"Вопрос: {state['user_query']}\n",
            f"Текущий шаг: {state['step']} из 6",
            f"История поиска: {len(state['search_history'])} запросов\n"
        ]
        
        # Показываем найденные элементы (для оценки достаточности)
        if state['found_items']:
            context_parts.append(f"Найденные элементы ({len(state['found_items'])} всего):")
            for i, item in enumerate(state['found_items'][-10:], 1):
                context_parts.append(f"  {i}. {json.dumps(item, ensure_ascii=False)}")
        else:
            context_parts.append("Найденные элементы: НИЧЕГО НЕ НАЙДЕНО")
        
        # Показываем доказательства
        if state['evidence']:
            context_parts.append(f"\nДоказательства ({len(state['evidence'])} всего, показаны последние 5):")
            for e in state['evidence'][-5:]:
                context_parts.append(f"  - {e}")
        else:
            context_parts.append("\nДоказательства: НЕТ")
        
        # Показываем пробелы
        if state['gaps']:
            context_parts.append("\nПробелы (что НЕ найдено):")
            context_parts.append("\n".join(f"  - {g}" for g in state['gaps']))
        else:
            context_parts.append("\nПробелы: всё найдено")
        
        # Показываем исходные гипотезы для контекста
        context_parts.append("\nИсходные гипотезы:")
        context_parts.append("\n".join(f"  - {h}" for h in state['hypotheses']))
        
        context = "\n".join(context_parts)

        invoke_config = {}
        if llm_logger._enabled:
            invoke_config = {
                "callbacks": [LangChainFileLogger(llm_logger, step_prefix="REFINER")]
            }

        result: RefinementDecision = structured_llm.invoke(
            [
                {"role": "system", "content": _build_refiner_system()},
                {"role": "user", "content": context}
            ],
            config=invoke_config,
        )

        state["done"] = not result.continue_search

        logger.info(
            f"Refiner принял решение\n"
            f"  Продолжить: {result.continue_search}\n"
            f"  Обоснование: {result.reasoning}\n"
            f"  Следующая стратегия: {result.next_strategy}"
        )

        llm_logger.log_stage(
            "REFINER COMPLETE",
            f"Решение: {'продолжить' if result.continue_search else 'завершить'}\n"
            f"Обоснование: {result.reasoning}\n"
            f"Следующая стратегия: {result.next_strategy}"
        )

    except Exception as exc:
        logger.error(f"Ошибка refiner: {exc}", exc_info=True)
        # Fallback: продолжаем если шагов мало и есть gaps
        state["done"] = state["step"] >= 4 or len(state["gaps"]) == 0

    return state


def finalizer(state: AgentState) -> AgentState:
    """
    Формирует финальный ответ на основе собранных данных.
    """
    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "FINALIZER START",
        f"Шагов выполнено: {state['step']}\n"
        f"Найдено элементов: {len(state['found_items'])}\n"
        f"Доказательств: {len(state['evidence'])}"
    )

    try:
        llm = rag_chat.build_llm()

        # Формируем контекст для финального ответа
        context_parts = [
            f"Вопрос пользователя: {state['user_query']}\n",
            f"\nВыполнено шагов поиска: {state['step']}",
            f"\nИстория поиска:\n" + "\n".join(f"  {i+1}. {q}" for i, q in enumerate(state['search_history'])),
        ]

        if state["found_items"]:
            context_parts.append(
                f"\n\nНайденные элементы ({len(state['found_items'])}):\n"
                + "\n".join(json.dumps(item, ensure_ascii=False, indent=2) for item in state['found_items'][:20])
            )

        if state["evidence"]:
            context_parts.append(
                f"\n\nДоказательства:\n"
                + "\n".join(f"  - {e}" for e in state['evidence'][:20])
            )

        if state["gaps"]:
            context_parts.append(
                f"\n\nПробелы (не найдено):\n"
                + "\n".join(f"  - {g}" for g in state['gaps'])
            )

        context = "".join(context_parts)

        invoke_config = {}
        if llm_logger._enabled:
            invoke_config = {
                "callbacks": [LangChainFileLogger(llm_logger, step_prefix="FINALIZER")]
            }

        # Вызываем LLM без структурирования (свободный ответ)
        response = llm.invoke(
            [
                {"role": "system", "content": _build_finalizer_system()},
                {"role": "user", "content": context}
            ],
            config=invoke_config,
        )

        answer = response.content if hasattr(response, 'content') else str(response)
        state["final_answer"] = answer

        logger.info(f"Finalizer сформировал ответ\n  Длина: {len(answer)} символов")

        llm_logger.log_stage(
            "FINALIZER COMPLETE",
            f"Ответ сформирован: {len(answer)} символов"
        )

    except Exception as exc:
        logger.error(f"Ошибка finalizer: {exc}", exc_info=True)
        state["final_answer"] = (
            f"Не удалось сформировать финальный ответ из-за ошибки: {exc}\n\n"
            f"Найдено элементов: {len(state['found_items'])}"
        )

    return state


# ---------------------------------------------------------------------------
# Логика переходов
# ---------------------------------------------------------------------------

def should_continue(state: AgentState) -> Literal["finalizer", "tool_selector"]:
    """
    Определяет следующий узел после refiner.
    """
    if state["done"]:
        return "finalizer"
    if state["step"] > 6:
        return "finalizer"
    return "tool_selector"


# ---------------------------------------------------------------------------
# Построение графа
# ---------------------------------------------------------------------------

def build_graph() -> Any:
    """
    Создает LangGraph state machine для итеративного поиска.
    """
    workflow = StateGraph(AgentState)

    # Добавляем узлы
    # workflow.add_node("prefetch_sections", prefetch_sections)  # ОТКЛЮЧЕНО
    workflow.add_node("planner", planner)
    workflow.add_node("section_finder", section_finder)
    workflow.add_node("tool_selector", tool_selector)
    workflow.add_node("tool_executor", tool_executor)
    workflow.add_node("analyzer", analyzer)
    workflow.add_node("refiner", refiner)
    workflow.add_node("finalizer", finalizer)

    # Определяем рёбра (transitions)
    workflow.set_entry_point("planner")  # ИЗМЕНЕНО: начинаем сразу с planner
    # workflow.add_edge("prefetch_sections", "planner")  # ОТКЛЮЧЕНО
    workflow.add_edge("planner", "section_finder")
    workflow.add_edge("section_finder", "tool_selector")
    workflow.add_edge("tool_selector", "tool_executor")
    workflow.add_edge("tool_executor", "analyzer")
    workflow.add_edge("analyzer", "refiner")

    # Условный переход от refiner
    workflow.add_conditional_edges(
        "refiner",
        should_continue,
        {
            "tool_selector": "tool_selector",
            "finalizer": "finalizer",
        }
    )

    workflow.add_edge("finalizer", END)

    return workflow.compile()


# ---------------------------------------------------------------------------
# Основная функция выполнения
# ---------------------------------------------------------------------------

def run_query(question: str, verbose: bool = False) -> dict:
    """
    Выполняет итеративный поиск по вопросу.

    Args:
        question: Вопрос пользователя
        verbose: Режим подробного вывода

    Returns:
        Финальное состояние агента
    """
    llm_logger = _get_llm_logger()
    llm_logger.log_stage(
        "QUERY START",
        f"""Вопрос: {question}
Режим: {'verbose' if verbose else 'normal'}"""
    )

    # Создаем граф
    graph = build_graph()

    # Инициализируем состояние
    initial_state: AgentState = {
        "user_query": question,
        "hypotheses": [],
        "search_history": [],
        "found_items": [],
        "evidence": [],
        "gaps": [],
        "last_tool": "",
        "last_query": "",
        "last_result": None,
        "step": 0,
        "done": False,
        "final_answer": "",
        "key_terms": [],  # Будет заполнено в planner
        "semantic_queries": [],  # Будет заполнено в planner
        "found_sections": [],  # Будет заполнено в section_finder
        "all_chunks": [],  # Будет накапливать все чанки
        "sections_searched": False,  # Флаг завершения поиска разделов
    }

    # Запускаем граф
    try:
        final_state = graph.invoke(initial_state)

        llm_logger.log_stage(
            "QUERY COMPLETE",
            f"Шагов выполнено: {final_state['step']}\n"
            f"Найдено элементов: {len(final_state['found_items'])}\n"
            f"Доказательств: {len(final_state['evidence'])}\n"
            f"Длина ответа: {len(final_state['final_answer'])} символов"
        )

        return final_state

    except Exception as exc:
        logger.error(f"Ошибка выполнения графа: {exc}", exc_info=True)
        llm_logger.log_stage("QUERY ERROR", f"Ошибка: {exc}")
        raise


# ---------------------------------------------------------------------------
# Вывод результатов
# ---------------------------------------------------------------------------

def print_result(question: str, state: dict, verbose: bool = False) -> None:
    """
    Выводит результаты работы агента.
    """
    SEP = "=" * 80

    print(f"\n{SEP}")
    print(f"Вопрос: {question}")
    print(f"Шагов выполнено: {state['step']}")
    print(f"История поиска: {len(state['search_history'])} запросов")
    print(SEP)

    if verbose:
        print("\nИстория поиска:")
        for i, q in enumerate(state['search_history'], 1):
            print(f"  {i}. {q}")

        print(f"\nНайдено элементов: {len(state['found_items'])}")
        if state['found_items']:
            for i, item in enumerate(state['found_items'][:10], 1):
                print(f"  {i}. {json.dumps(item, ensure_ascii=False)[:200]}...")

        print(f"\nДоказательства: {len(state['evidence'])}")
        if state['evidence']:
            for i, e in enumerate(state['evidence'][:5], 1):
                print(f"  {i}. {e[:150]}...")

        if state['gaps']:
            print(f"\nПробелы:")
            for g in state['gaps']:
                print(f"  - {g}")

    print(f"\n{SEP}")
    print("ОТВЕТ:")
    print(SEP)
    print(state['final_answer'])
    print(SEP)


# ---------------------------------------------------------------------------
# Интерактивный режим
# ---------------------------------------------------------------------------

def run_interactive(verbose: bool = False) -> None:
    """
    Запускает интерактивный режим для многократных вопросов.
    """
    SEP = "=" * 80
    print(f"\n{SEP}")
    print("LangGraph RAG-агент для итеративного поиска")
    print("  /verbose — переключить подробный вывод")
    print("  exit / quit / выход — выйти")
    print(f"{SEP}\n")

    while True:
        try:
            question = input("Вопрос: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nВыход.")
            break

        if not question:
            continue
        if question.lower() in ("exit", "quit", "выход"):
            print("До свидания!")
            break
        if question.lower() == "/verbose":
            verbose = not verbose
            print(f"Verbose: {'включён' if verbose else 'выключен'}.")
            continue

        try:
            state = run_query(question, verbose=verbose)
            print_result(question, state, verbose=verbose)
        except Exception as exc:
            logger.error(f"Ошибка выполнения: {exc}", exc_info=True)
            print(f"\n[!] Ошибка: {exc}")


# ---------------------------------------------------------------------------
# Точка входа
# ---------------------------------------------------------------------------

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="LangGraph RAG-агент для итеративного поиска и анализа"
    )
    parser.add_argument(
        "question",
        nargs="*",
        help="Вопрос (если не указан — интерактивный режим)",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Показывать детали процесса поиска",
    )
    return parser.parse_args()


def main() -> None:
    args = parse_args()

    logger.info(f"""Запуск LangGraph RAG-агента
  LLM:         {settings.ollama_model}
  Эмбеддинги:  {settings.ollama_embed_model}
  Источники:   {settings.knowledge_dir}
  ClickHouse:  {settings.clickhouse_host}:{settings.clickhouse_port}
  Логирование: {'включено' if settings.llm_log_enabled else 'отключено'}""")

    if args.question:
        question = " ".join(args.question)
        state = run_query(question, verbose=args.verbose)
        print_result(question, state, verbose=args.verbose)
    else:
        run_interactive(verbose=args.verbose)


if __name__ == "__main__":
    main()

