# RAG Configuration Example
# Скопируйте в .env и настройте под свои параметры

# === Ollama LLM ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b                # Базовая модель для всех этапов (plan, action, observation, refine)
# OLLAMA_FINAL_MODEL=qwen2.5:14b       # Более мощная модель для финального ответа (final_node)
OLLAMA_FINAL_MODEL=hf.co/hesamation/Qwen3.6-35B-A3B-Claude-4.6-Opus-Reasoning-Distilled-GGUF:Q4_K_M  # Claude-distilled модель для финального ответа
OLLAMA_EMBED_MODEL=bge-m3            # Модель для эмбеддингов

# === Knowledge Base ===
KNOWLEDGE_DIR=Z:\ES-Leasing\СОИБ КЦОИ

# === ClickHouse ===
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=clickhouse
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=soib_kcoi_v2
CLICKHOUSE_TABLE=chunks

# === Retrieval Settings ===
RETRIEVER_TOP_K=10
MAX_CONTEXT_CHARS=100000

# === Logging ===
LLM_LOG_ENABLED=true

# === Memory ===
AGENT_MEMORY_ENABLED=true
AGENT_MEMORY_TABLE=agent_memory

