        "inputAnchors": [
          { "label": "Tools", "name": "tools", "type": "Tool", "list": true, "id": "toolAgent_0-input-tools-Tool", "display": true },
          { "label": "Chat Model", "name": "model", "type": "BaseChatModel", "id": "toolAgent_0-input-model-BaseChatModel", "display": true },
          { "label": "Memory", "name": "memory", "type": "BaseChatMemory", "optional": true, "id": "toolAgent_0-input-memory-BaseChatMemory", "display": true },
          { "label": "Input Moderation", "name": "inputModeration", "type": "Moderation", "optional": true, "list": true, "id": "toolAgent_0-input-inputModeration-Moderation", "display": true }
